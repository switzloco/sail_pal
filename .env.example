# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path. WAL journal files (.db-wal, .db-shm) are created alongside.
# The directory must exist before starting (start.sh creates it automatically).
DATABASE_URL=sqlite:///./backend/data/vessel.db

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of the running Ollama daemon.
OLLAMA_HOST=http://localhost:11434

# Model to use for all AI queries.
# Recommended values:
#   gemma4:12b  — 8–16 GB RAM laptops (MacBook Air M3/M4, most mid-range laptops)
#   gemma4:27b  — 32 GB+ RAM (MacBook Pro M3 Max, high-RAM workstations)
#                 The 27b variant uses a mixture-of-experts architecture and
#                 produces noticeably better medical and engineering guidance.
OLLAMA_MODEL=gemma4:12b

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL the browser uses to reach the backend.
# Change to the machine's LAN IP if accessing from another device on the network.
# Example: NEXT_PUBLIC_API_BASE=http://192.168.1.42:8000
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your LAN IP if needed.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Cloud simulation mode ─────────────────────────────────────────────────────
# Set CLOUD_MODE=true to skip Ollama entirely and route all AI calls through
# Google AI Studio (gemma-4-26b-a4b-it). Useful for dev and for distributing
# preview builds to testers who haven't installed Ollama.
# A "Cloud preview" banner appears in the UI whenever this is enabled.
# NEVER enable this on a vessel at sea — data leaves the device.
CLOUD_MODE=false
GOOGLE_API_KEY=

# Cloud model to use when CLOUD_MODE=true. Options visible at ai.google.dev:
#   gemma-4-26b-a4b-it  — 4B active / 26B MoE, closest to 12B edge quality
#   gemma-4-31b-it      — strongest; responses will exceed edge-model quality
CLOUD_MODEL=gemma-4-26b-a4b-it

# ── Firebase (Phase 2 — sync when in port) ───────────────────────────────────
# Leave blank for Phase 1. Sync queue accumulates locally and pushes to
# Firestore when internet is available and sync is triggered.
# FIREBASE_PROJECT_ID=
# FIREBASE_CREDENTIALS_JSON=  # path to service account JSON
