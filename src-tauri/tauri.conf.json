{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vessel Ops AI",
  "version": "0.1.0",
  "identifier": "ai.vesselops.app",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev -- -p 3000",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm --prefix ../frontend run build:tauri",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "Vessel Ops AI",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Offline maritime AI assistant",
    "longDescription": "Vessel Ops AI is an offline-first assistant for crew health, engine maintenance, and vessel operations. Uses local Gemma via Ollama — no cloud, no internet required at sea.",
    "externalBin": ["binaries/vessel-ops-backend"],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "perMachine": false,
        "displayLanguageSelector": false
      }
    }
  }
}
